# Copy to .env and fill in. Never commit the real .env.

# Personal API key: bitrefill.com/account/developers
BITREFILL_API_KEY=

# Free, OpenAI-compatible LLM provider that drives intent + allocation.
# Default targets OpenRouter free models. Get a free key at openrouter.ai/keys
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-120b:free
